{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>js-soft/renovate-config"],
    "additionalReviewers": ["erbenjak"],
    "packageRules": [
        {
            "description": "Don't report abandonment for these packages, because they are fine as they are.",
            "matchDatasources": ["nuget"],
            "matchPackageNames": ["Serilog.Formatting.Compact"],
            "abandonmentThreshold": null
        },
        {
            "description": "Don't update MediatR due to license issues",
            "matchDatasources": ["nuget"],
            "matchUpdateTypes": ["major"],
            "matchPackageNames": ["MediatR"],
            "enabled": false
        },
        {
            "description": "We want to update the Dart and Flutter versions manually.",
            "matchDatasources": ["dart-version", "flutter-version"],
            "enabled": false
        },
        {
            "description": "These images are built and used in the pipelines and should therefore not be updated by Renovate.",
            "matchDatasources": ["docker"],
            "matchPackageNames": [
                "ghcr.io/nmshd/backbone-consumer-api",
                "ghcr.io/nmshd/backbone-admin-ui",
                "ghcr.io/nmshd/backbone-event-handler",
                "ghcr.io/nmshd/backbone-sse-server",
                "ghcr.io/nmshd/backbone-database-migrator",
                "ghcr.io/nmshd/backbone-admin-cli"
            ],
            "enabled": false
        },
        {
            "matchDatasources": ["dart"],
            "matchPackageNames": ["window_size"],
            "enabled": false
        },
        {
            "description": "These are our own packages used as a monorepo and should therefore not be updated by Renovate.",
            "matchDatasources": ["dart"],
            "matchPackageNames": ["admin_api_sdk", "admin_api_types"],
            "enabled": false
        }
    ]
}
